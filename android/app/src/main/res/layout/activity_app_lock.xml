<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#faf5f5"
    android:padding="8dp">

    <!-- TIME LOCK ACTIVE Badge -->
    <TextView
        android:id="@+id/timeLockActiveText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TIME LOCK ACTIVE"
        android:textColor="#FFA500"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/time_lock_label_background"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:visibility="gone" />

    <!-- Biometric Icon Circle -->
    <FrameLayout
        android:id="@+id/fingerprintIconContainer"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/blue_circle_background"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/lockIcon"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_lock_lock"
            android:tint="#d21111"
            android:contentDescription="Lock icon" />
    </FrameLayout>

    <!-- Title: "Enter the PIN" -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter the PIN"
        android:textColor="#1A1A1A"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="2dp"
        android:layout_gravity="center_horizontal" />

    <!-- Subtitle: "Unlock to access StealthSeal" -->
    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Unlock to access StealthSeal"
        android:textColor="#888888"
        android:textSize="11sp"
        android:layout_marginBottom="12dp"
        android:layout_gravity="center_horizontal" />

    <!-- PIN Indicator Dots -->
    <LinearLayout
        android:id="@+id/pinDotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp"
        android:layout_gravity="center_horizontal">

        <View
            android:id="@+id/dot1"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="6dp"
            android:background="@android:color/transparent"
            android:contentDescription="PIN dot 1" />

        <View
            android:id="@+id/dot2"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="6dp"
            android:background="@android:color/transparent"
            android:contentDescription="PIN dot 2" />

        <View
            android:id="@+id/dot3"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="6dp"
            android:background="@android:color/transparent"
            android:contentDescription="PIN dot 3" />

        <View
            android:id="@+id/dot4"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="6dp"
            android:background="@android:color/transparent"
            android:contentDescription="PIN dot 4" />

        <View
            android:id="@+id/dot5"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="6dp"
            android:background="@android:color/transparent"
            android:contentDescription="PIN dot 5" />

        <View
            android:id="@+id/dot6"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="6dp"
            android:background="@android:color/transparent"
            android:contentDescription="PIN dot 6" />
    </LinearLayout>

    <!-- Error Message Text -->
    <TextView
        android:id="@+id/errorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#D32F2F"
        android:textSize="10sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:layout_gravity="center_horizontal"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Unlock Time Remaining Box -->
    <LinearLayout
        android:id="@+id/timeLockCountdownContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:background="@drawable/time_lock_countdown_background"
        android:visibility="gone">

        <!-- Label Row (Horizontal) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_dialog_info"
                android:tint="#C4435F"
                android:layout_marginEnd="8dp"
                android:contentDescription="Time lock info" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unlock Time Remaining"
                android:textColor="#C4435F"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Countdown Display -->
        <TextView
            android:id="@+id/timeLockCountdownText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="#C4435F"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center" />
    </LinearLayout>

    <!-- Pattern Lock Container -->
    <FrameLayout
        android:id="@+id/patternLockContainer"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="24dp"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"
        android:background="@android:color/transparent">

        <com.example.stealthseal.PatternView
            android:id="@+id/patternView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />
    </FrameLayout>

    <!-- Fingerprint Button -->
    <FrameLayout
        android:id="@+id/fingerprintButtonContainer"
        android:layout_width="85dp"
        android:layout_height="85dp"
        android:background="@drawable/blue_circle_background"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:layout_gravity="center_horizontal">

        <ImageView
            android:id="@+id/fingerprintIcon"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_secure"
            android:tint="#eae4e4"
            android:contentDescription="Fingerprint" />
    </FrameLayout>

    <!-- Fingerprint Help Text -->
    <TextView
        android:id="@+id/fingerprintHelpText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap to unlock"
        android:textColor="#1976D2"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        android:layout_gravity="center_horizontal"
        android:visibility="visible" />



    <!-- Numeric Keypad (3x3 grid + 0 + delete) -->
    <GridLayout
        android:id="@+id/keypadGrid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4"
        android:layout_marginTop="16dp"
        android:useDefaultMargins="false"
        android:layout_gravity="center_horizontal">

        <!-- Row 1: 1, 2, 3 -->
        <Button
            android:id="@+id/btn1"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_row="0"
            android:layout_column="0"
            android:layout_margin="10dp"
            android:text="1"
            android:textColor="#1A1A1A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/keypad_button_background"
            android:elevation="3dp" />

        <Button
            android:id="@+id/btn2"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_row="0"
            android:layout_column="1"
            android:layout_margin="10dp"
            android:text="2"
            android:textColor="#1A1A1A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/keypad_button_background"
            android:elevation="3dp" />

        <Button
            android:id="@+id/btn3"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_row="0"
            android:layout_column="2"
            android:layout_margin="10dp"
            android:text="3"
            android:textColor="#1A1A1A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/keypad_button_background"
            android:elevation="3dp" />

        <!-- Row 2: 4, 5, 6 -->
        <Button
            android:id="@+id/btn4"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_row="1"
            android:layout_column="0"
            android:layout_margin="10dp"
            android:text="4"
            android:textColor="#1A1A1A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/keypad_button_background"
            android:elevation="3dp" />

        <Button
            android:id="@+id/btn5"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_row="1"
            android:layout_column="1"
            android:layout_margin="10dp"
            android:text="5"
            android:textColor="#1A1A1A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/keypad_button_background"
            android:elevation="3dp" />

        <Button
            android:id="@+id/btn6"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_row="1"
            android:layout_column="2"
            android:layout_margin="10dp"
            android:text="6"
            android:textColor="#1A1A1A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/keypad_button_background"
            android:elevation="3dp" />

        <!-- Row 3: 7, 8, 9 -->
        <Button
            android:id="@+id/btn7"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_row="2"
            android:layout_column="0"
            android:layout_margin="10dp"
            android:text="7"
            android:textColor="#1A1A1A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/keypad_button_background"
            android:elevation="3dp" />

        <Button
            android:id="@+id/btn8"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_row="2"
            android:layout_column="1"
            android:layout_margin="10dp"
            android:text="8"
            android:textColor="#1A1A1A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/keypad_button_background"
            android:elevation="3dp" />

        <Button
            android:id="@+id/btn9"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_row="2"
            android:layout_column="2"
            android:layout_margin="10dp"
            android:text="9"
            android:textColor="#1A1A1A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/keypad_button_background"
            android:elevation="3dp" />

        <!-- Row 4: Empty, 0, Delete -->
        <Space
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_row="3"
            android:layout_column="0"
            android:layout_margin="10dp" />

        <Button
            android:id="@+id/btn0"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_row="3"
            android:layout_column="1"
            android:layout_margin="10dp"
            android:text="0"
            android:textColor="#1A1A1A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/keypad_button_background"
            android:elevation="3dp" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_row="3"
            android:layout_column="2"
            android:layout_margin="10dp"
            android:src="@android:drawable/ic_input_delete"
            android:tint="#1A1A1A"
            android:scaleType="center"
            android:background="@drawable/keypad_button_background"
            android:elevation="3dp"
            android:contentDescription="Delete" />
    </GridLayout>

</LinearLayout>